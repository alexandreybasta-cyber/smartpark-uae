// SmartPark API Keys Template
// Copy this file to Secrets.xcconfig and fill in your real keys
// Secrets.xcconfig is git-ignored and will NOT be committed
QWEN_API_KEY = your-qwen-api-key-here
QODER_AGENT_API_KEY = your-qoder-agent-key-here
SMARTPARK_API_BASE_URL = http:$(SLASH_SLASH)localhost:8000
